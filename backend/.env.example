# MongoDB connection string from Atlas (@ in password must be encoded as %40)
MONGO_URL=

# MongoDB database name
DB_NAME=

# OpenAI API key — required for article rewriting and micro-fact generation
OPENAI_API_KEY=

# Secret used to sign JWTs — use a random 32+ character string, never commit the real value
JWT_SECRET=

# OpenAI model to use for rewrites (default: gpt-4o-mini)
OPENAI_MODEL_DEFAULT=gpt-4o-mini

# Comma-separated allowed CORS origins. Use * for development, restrict in production
CORS_ORIGINS=*
